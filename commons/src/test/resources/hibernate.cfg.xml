<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-configuration PUBLIC "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
                                         "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
	<session-factory>
		<property name="hibernate.connection.username">sreadertest</property>
		<property name="hibernate.connection.password">sreadertest</property>
		<property name="hibernate.connection.url">jdbc:postgresql://postgres:5432/sreadertest</property>
		<property name="hibernate.dialect">org.hibernate.dialect.PostgreSQL82Dialect</property>
		<property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
		<property name="hibernate.bytecode.use_reflection_optimizer">false</property>
		<property name="hibernate.search.autoregister_listeners">false</property>
		<mapping class="net.sasasin.sreader.commons.entity.ContentHeader" />
		<mapping class="net.sasasin.sreader.commons.entity.FeedUrl" />
		<mapping class="net.sasasin.sreader.commons.entity.EftRules" />
		<mapping class="net.sasasin.sreader.commons.entity.ContentFullText" />
	</session-factory>
</hibernate-configuration>
