MAVEN_IMAGE=maven:3.9.11-eclipse-temurin-25
POSTGRES_IMAGE=postgres:17.10
POSTGRES_DB=sreader
POSTGRES_USER=sreader
POSTGRES_PASSWORD=sreader
POSTGRES_TEST_DB=sreadertest
POSTGRES_TEST_USER=sreadertest
POSTGRES_TEST_PASSWORD=sreadertest
POSTGRES_PORT=5432
FLYWAY_IMAGE=redgate/flyway:12.8.1
SREADER_SCHEDULER_ENABLED=true
SREADER_SCHEDULER_CRON=0 */15 * * * *
SREADER_HTTP_USER_AGENT=SReader/0.1
SREADER_PLAYWRIGHT_ENABLED=false
SREADER_PLAYWRIGHT_HEADLESS=true
SREADER_PLAYWRIGHT_INFY_EXTENSION_DIR=
SREADER_PLAYWRIGHT_INFY_USER_DATA_DIR=
SREADER_PLAYWRIGHT_INFY_MAX_SCROLLS=20
SREADER_PLAYWRIGHT_INFY_STABLE_ROUNDS=3
SREADER_PLAYWRIGHT_INFY_SCROLL_WAIT=2700ms
SREADER_SEED_FEED_URLS=
